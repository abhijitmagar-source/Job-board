DJANGO_SECRET_KEY=your-secret-key-here-min-32-chars
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database — SQLite default in development; PostgreSQL for production
# DATABASE_URL=postgresql://jobboard:jobboard@localhost:5432/jobboard

# Redis (optional in dev — LocMem cache used by default)
REDIS_URL=redis://127.0.0.1:6379/1
JOBS_LIST_CACHE_TTL=300

# CORS (Next.js dev server + Vercel)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Cloudinary (optional — local media fallback when unset)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email (password reset)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=noreply@jobboard.app

# Rate limits
THROTTLE_ANON=100/hour
THROTTLE_USER=1000/hour
