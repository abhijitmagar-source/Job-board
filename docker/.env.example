# Copy to docker/.env before: docker compose up --build

# Django
DJANGO_SECRET_KEY=change-me-to-a-long-random-string-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,backend,nginx
SECURE_SSL_REDIRECT=False

# MySQL (db service)
MYSQL_DATABASE=jobboard
MYSQL_USER=jobboard
MYSQL_PASSWORD=jobboard
MYSQL_ROOT_PASSWORD=rootsecret
MYSQL_PORT=3306

# Redis
REDIS_PORT=6379

# App ports (host)
BACKEND_PORT=8000
FRONTEND_PORT=3000
NGINX_HTTP_PORT=80

# Frontend → API (browser must reach host, not Docker service name)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost

# Cache
JOBS_LIST_CACHE_TTL=300
